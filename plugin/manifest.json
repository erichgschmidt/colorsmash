{
  "manifestVersion": 5,
  "id": "44bb5649",
  "name": "Color Smash",
  "version": "1.3.1",
  "description": "Per-channel histogram color match into a single editable Curves adjustment layer.",
  "author": {
    "name": "Erich Schmidt",
    "email": "erichgschmidt@gmail.com"
  },
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "25.0.0",
      "data": {
        "apiVersion": 2,
        "enableMenuRecording": true
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "colorSmashPanel",
      "label": { "default": "Color Smash" },
      "minimumSize": { "width": 220, "height": 300 },
      "maximumSize": { "width": 1000, "height": 2000 },
      "preferredDockedSize": { "width": 260, "height": 800 },
      "preferredFloatingSize": { "width": 260, "height": 800 },
      "icons": [
        { "width": 23, "height": 23, "path": "icons/icon-light.png", "scale": [1, 2], "theme": ["lightest", "light", "medium"], "species": ["chrome"] },
        { "width": 23, "height": 23, "path": "icons/icon-dark.png", "scale": [1, 2], "theme": ["dark", "darkest"], "species": ["chrome"] }
      ]
    }
  ],
  "icons": [
    { "width": 23, "height": 23, "path": "icons/icon-light.png", "scale": [1, 2], "theme": ["lightest", "light", "medium"] },
    { "width": 23, "height": 23, "path": "icons/icon-dark.png", "scale": [1, 2], "theme": ["dark", "darkest"] }
  ]
}
