{
  "manifestVersion": 5,
  "id": "com.colorsmash.plugin",
  "name": "Color Smash",
  "version": "0.0.1",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "25.0.0",
      "data": {
        "apiVersion": 2,
        "enableMenuRecording": true
      }
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "colorSmashPanel",
      "label": { "default": "Color Smash" },
      "minimumSize": { "width": 320, "height": 400 },
      "preferredDockedSize": { "width": 360, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "plugin"
  },
  "icons": [
    { "width": 23, "height": 23, "path": "icons/icon-light.png", "scale": [1, 2], "theme": ["lightest", "light", "medium"] },
    { "width": 23, "height": 23, "path": "icons/icon-dark.png", "scale": [1, 2], "theme": ["dark", "darkest"] }
  ]
}
